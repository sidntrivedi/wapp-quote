{
  "name": "wapp-quote",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Daily uplifting Hindi quote bot for a WhatsApp group.",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/cli.ts",
    "start": "node dist/src/cli.js serve",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.test.json --noEmit",
    "validate:quotes": "tsx src/scripts/validate-quotes.ts"
  },
  "dependencies": {
    "@whiskeysockets/baileys": "^6.7.23",
    "dotenv": "^17.4.2",
    "node-cron": "^4.4.1",
    "pino": "^9.14.0",
    "qrcode": "^1.5.4",
    "qrcode-terminal": "^0.12.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^22.20.0",
    "@types/qrcode": "^1.5.6",
    "@types/qrcode-terminal": "^0.12.2",
    "@vitest/coverage-v8": "^4.1.9",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.9"
  }
}
