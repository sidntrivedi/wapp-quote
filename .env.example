# WhatsApp target group JID, discovered with:
# npm run dev -- list-groups
WHATSAPP_GROUP_JID=

# Quote source:
# wikiquote = fetch public Hindi Wikiquote pages, then fall back to local curated quotes.
# local = use only src/data/quotes.json.
QUOTE_SOURCE=wikiquote
WIKIQUOTE_LANGUAGE=hi
WIKIQUOTE_MODE=pages
# Leave WIKIQUOTE_PAGES unset to use the built-in approved author list.
# Optional override format: Wikiquote page|message author.
# WIKIQUOTE_PAGES=कबीर|कबीर,रहीम|रहीम,तुलसीदास|तुलसीदास
# Random modes are available but less reliable for attribution:
# WIKIQUOTE_MODE=authors
# WIKIQUOTE_CATEGORIES=लेखक,दार्शनिक,भारत के कवि
# WIKIQUOTE_RANDOM_PAGE_LIMIT=50

# Optional AI reflection. For cloud server deployment, use openai or ollama-cloud.
# none = render the quote with its built-in fallback reflection.
# openai = call OpenAI Chat Completions with OPENAI_API_KEY.
# ollama-cloud = call https://ollama.com/api/chat with OLLAMA_API_KEY.
AI_PROVIDER=none
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OLLAMA_BASE_URL=https://ollama.com/api
OLLAMA_API_KEY=
OLLAMA_MODEL=gpt-oss:120b
AI_TIMEOUT_MS=10000
AI_TEMPERATURE=0.7

# Daily schedule in 24-hour local time.
QUOTE_TIME=06:00
TZ=Asia/Kolkata

# Poll for missed sends after QUOTE_TIME (within a 4-hour window). Default: true.
QUOTE_CATCH_UP=true

# Pairing is usually easiest on a VPS. Use only digits with country code.
AUTH_METHOD=pairing
PAIRING_PHONE_NUMBER=919876543210

# Runtime paths. Defaults are shown here for clarity.
DATA_DIR=./data
AUTH_DIR=./data/auth
STATE_FILE=./data/state.json

# Logging: trace, debug, info, warn, error, fatal, silent
LOG_LEVEL=info

# --- Health webhook (Apple Shortcuts → WhatsApp) ---
# When enabled, the serve process also runs an HTTP server that accepts a daily
# health payload from an Apple Shortcut, stores it, and posts a Hindi report.
HEALTH_WEBHOOK_ENABLED=false
# Port the webhook listens on (Fly maps 443/80 → this internal port).
HEALTH_WEBHOOK_PORT=8080
# Long random secret. Send it as `Authorization: Bearer <token>` or `x-webhook-token`.
HEALTH_WEBHOOK_TOKEN=
# Group to post health reports to. Falls back to WHATSAPP_GROUP_JID when unset.
HEALTH_GROUP_JID=
# Daily steps goal used for the ✅ mark and the streak insight.
HEALTH_STEP_GOAL=8000
